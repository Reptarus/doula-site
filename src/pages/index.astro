---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="[Name] Doula | Birth & Postpartum Support in Marysville, WA">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-eyebrow">Birth Support &bull; Marysville, WA</div>
      <h1 class="hero-title">Nurturing your journey into <em>motherhood</em></h1>
      <p class="hero-subtitle">
        Compassionate, personalized doula care to support you through pregnancy, birth,
        and the early postpartum days. You deserve someone in your corner.
      </p>
      <a href="/book" class="btn btn-primary">
        Book a Free Consultation
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
    <div class="hero-image">
      <!--
        TODO: Replace with actual image
        <img src="/images/hero.jpg" alt="[Name] supporting a family" />
      -->
      <div class="hero-placeholder">
        <p>Hero Photo</p>
        <span>Replace with a warm portrait or lifestyle image</span>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-bar">
    <div class="trust-item">
      <div class="trust-number">50+</div>
      <div class="trust-label">Families Supported</div>
    </div>
    <div class="trust-item">
      <div class="trust-number">5.0</div>
      <div class="trust-label">Google Rating</div>
    </div>
    <div class="trust-item">
      <div class="trust-number">8+</div>
      <div class="trust-label">Years Experience</div>
    </div>
    <div class="trust-item">
      <!-- TODO: Replace with real certification -->
      <div class="trust-number">DONA</div>
      <div class="trust-label">Certified</div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="section services-section">
    <div class="section-header">
      <div class="eyebrow">What I Offer</div>
      <h2 class="section-title">Services</h2>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🤰</div>
        <h3>Birth Doula</h3>
        <p>Continuous support during labor and delivery, plus prenatal visits and a postpartum check-in.</p>
        <div class="price">From $X,XXX</div>
      </div>
      <div class="service-card">
        <div class="service-icon">🌙</div>
        <h3>Postpartum Support</h3>
        <p>In-home support with newborn care, feeding guidance, and emotional recovery after birth.</p>
        <div class="price">From $XX/hr</div>
      </div>
      <div class="service-card">
        <div class="service-icon">💬</div>
        <h3>Free Consultation</h3>
        <p>A 30-minute call to meet, ask questions, and see if we're a good fit for your birth journey.</p>
        <div class="price">Free</div>
      </div>
    </div>
    <div class="services-cta">
      <a href="/services" class="btn btn-outline">View All Services</a>
    </div>
  </section>

  <!-- Brief About Teaser -->
  <section class="section about-teaser">
    <div class="about-teaser-inner">
      <div class="about-teaser-image">
        <!-- TODO: Replace with photo -->
        <div class="image-placeholder">Photo</div>
      </div>
      <div class="about-teaser-text">
        <div class="eyebrow">About Me</div>
        <h2>Every birth story is <em>unique</em></h2>
        <p>
          I believe every family deserves compassionate, judgment-free support during one of
          life's most transformative experiences. Whether this is your first baby or your fifth,
          I'm here to help you feel informed, empowered, and cared for.
        </p>
        <a href="/about" class="btn btn-outline">Learn More About Me</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 64px;
    background: var(--color-warm-white);
  }
  .hero-eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-sage);
    margin-bottom: 20px;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-charcoal);
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .hero-title em {
    font-style: italic;
    color: var(--color-sage-dark);
  }
  .hero-subtitle {
    font-size: 17px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-warm-gray);
    max-width: 460px;
    margin-bottom: 40px;
  }
  .hero-image {
    background: var(--color-sage-light);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .hero-placeholder {
    text-align: center;
    color: var(--color-sage-dark);
    opacity: 0.6;
  }
  .hero-placeholder p {
    font-size: 20px;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .hero-placeholder span {
    font-size: 13px;
  }

  /* Trust Bar */
  .trust-bar {
    display: flex;
    justify-content: center;
    gap: 64px;
    padding: 40px 48px;
    background: var(--color-cream);
    border-top: 1px solid var(--color-light-gray);
    border-bottom: 1px solid var(--color-light-gray);
  }
  .trust-item { text-align: center; }
  .trust-number {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 600;
    color: var(--color-sage-dark);
  }
  .trust-label {
    font-size: 13px;
    color: var(--color-warm-gray);
    margin-top: 4px;
  }

  /* Services */
  .services-section {
    background: var(--color-warm-white);
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .service-card {
    background: var(--color-warm-white);
    padding: 40px 32px;
    border: 1px solid var(--color-light-gray);
    transition: all 0.3s ease;
  }
  .service-card:hover {
    border-color: var(--color-sage-light);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.06);
  }
  .service-icon {
    font-size: 32px;
    margin-bottom: 20px;
  }
  .service-card h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    margin-bottom: 12px;
  }
  .service-card p {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-warm-gray);
    margin-bottom: 20px;
  }
  .price {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-sage-dark);
  }
  .services-cta {
    text-align: center;
    margin-top: 48px;
  }

  /* About Teaser */
  .about-teaser {
    background: var(--color-cream);
  }
  .about-teaser-inner {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 64px;
    max-width: var(--max-width);
    margin: 0 auto;
    align-items: center;
  }
  .about-teaser-image {
    aspect-ratio: 4/5;
    background: var(--color-sage-light);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-sage-dark);
    opacity: 0.6;
    font-size: 14px;
  }
  .about-teaser-text h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 400;
    margin-bottom: 20px;
    line-height: 1.2;
  }
  .about-teaser-text h2 em {
    font-style: italic;
    color: var(--color-sage-dark);
  }
  .about-teaser-text p {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-warm-gray);
    margin-bottom: 32px;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
    }
    .hero-content {
      padding: 48px 24px;
    }
    .hero-image {
      min-height: 300px;
    }
    .trust-bar {
      flex-wrap: wrap;
      gap: 32px;
    }
    .services-grid {
      grid-template-columns: 1fr;
    }
    .about-teaser-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .about-teaser-image {
      max-height: 300px;
    }
  }
</style>
