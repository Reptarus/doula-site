---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | [Name] Doula">

  <section class="about-hero">
    <div class="about-grid">
      <div class="about-photo">
        <!-- TODO: Replace with actual portrait photo -->
        <div class="photo-placeholder">Portrait Photo</div>
      </div>
      <div class="about-text">
        <div class="eyebrow">About Me</div>
        <h1>Hi, I'm <em>[Name]</em></h1>

        <!-- TODO: Replace all paragraph text with your wife's real story -->
        <p>
          This is where your story goes — why you became a doula, what drives your
          passion for supporting families through one of life's most transformative
          experiences. Make it personal, warm, and authentic.
        </p>
        <p>
          Talk about your approach here — evidence-based care, non-judgmental
          support, honoring each family's unique birth preferences and circumstances.
          What can families expect when they work with you?
        </p>
        <p>
          You might mention being a mother yourself and understanding firsthand
          the power and vulnerability of bringing new life into the world.
        </p>

        <!-- TODO: Replace with real certifications -->
        <div class="credentials">
          <span class="credential-tag">DONA Certified</span>
          <span class="credential-tag">CPR Certified</span>
          <span class="credential-tag">Lactation Support</span>
          <span class="credential-tag">Spinning Babies</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Optional: Values / Philosophy -->
  <section class="section values-section">
    <div class="section-header">
      <div class="eyebrow">My Philosophy</div>
      <h2 class="section-title">What I Believe</h2>
    </div>
    <div class="values-grid">
      <div class="value-card">
        <h3>Your Body, Your Birth</h3>
        <p>You are the expert on your own body. My role is to inform, support, and advocate — never to decide for you.</p>
      </div>
      <div class="value-card">
        <h3>No Judgment, Ever</h3>
        <p>Whether you're planning a home birth or a scheduled cesarean, every choice you make for your family is valid and supported.</p>
      </div>
      <div class="value-card">
        <h3>Continuous Presence</h3>
        <p>When labor begins, I'm there — for as long as it takes. You'll never be alone during the moments that matter most.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="cta-inner">
      <h2>Ready to meet?</h2>
      <p>Book a free 30-minute consultation to see if we're a good fit.</p>
      <a href="/book" class="btn btn-primary">Schedule a Call</a>
    </div>
  </section>

</BaseLayout>

<style>
  .about-hero {
    background: var(--color-warm-white);
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 64px;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px 48px;
    align-items: center;
  }
  .about-photo {
    background: var(--color-sage-light);
    aspect-ratio: 3/4;
    overflow: hidden;
  }
  .photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-sage-dark);
    opacity: 0.6;
    font-size: 14px;
  }
  .about-text h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 42px);
    font-weight: 400;
    margin-bottom: 24px;
    line-height: 1.15;
  }
  .about-text h1 em {
    font-style: italic;
    color: var(--color-sage-dark);
  }
  .about-text p {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-warm-gray);
    margin-bottom: 16px;
  }
  .credentials {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .credential-tag {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 8px 16px;
    background: var(--color-cream);
    border: 1px solid var(--color-light-gray);
    color: var(--color-warm-gray);
  }

  /* Values */
  .values-section {
    background: var(--color-cream);
  }
  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .value-card {
    text-align: center;
    padding: 32px;
  }
  .value-card h3 {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    margin-bottom: 12px;
    color: var(--color-charcoal);
  }
  .value-card p {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-warm-gray);
  }

  /* CTA */
  .cta-section {
    background: var(--color-sage);
    text-align: center;
  }
  .cta-inner h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 38px);
    color: white;
    margin-bottom: 12px;
  }
  .cta-inner p {
    color: rgba(255,255,255,0.8);
    font-weight: 300;
    margin-bottom: 32px;
  }
  .cta-section .btn-primary {
    background: white;
    color: var(--color-sage-dark);
  }
  .cta-section .btn-primary:hover {
    background: var(--color-cream);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      padding: 48px 24px;
      gap: 32px;
    }
    .about-photo {
      max-height: 350px;
    }
    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
